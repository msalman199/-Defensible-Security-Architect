Task 3: Install and Configure NTP Service
Step 1: Install NTP Daemon
# Install NTP and monitoring tools
sudo apt install -y ntp ntpstat

# Create statistics directory
sudo mkdir -p /var/log/ntpstats
sudo chown ntp:ntp /var/log/ntpstats
Step 2: Configure NTP with Security Settings
# Backup original configuration
sudo cp /etc/ntp.conf /etc/ntp.conf.backup

# Create secure NTP configuration
sudo tee /etc/ntp.conf > /dev/null << 'EOF'
# Secure NTP Configuration

# Public NTP pool servers
server 0.pool.ntp.org iburst
server 1.pool.ntp.org iburst
server 2.pool.ntp.org iburst

# Access restrictions
restrict default kod nomodify notrap nopeer noquery
restrict -6 default kod nomodify notrap nopeer noquery
restrict 127.0.0.1
restrict -6 ::1

# Statistics
statsdir /var/log/ntpstats/
statistics loopstats peerstats
filegen loopstats file loopstats type day enable
filegen peerstats file peerstats type day enable

driftfile /var/lib/ntp/ntp.drift
EOF

# Restart NTP service
sudo systemctl restart ntp
sudo systemctl enable ntp
Step 3: Verify NTP Operation
# Check service status
sudo systemctl status ntp

# View peer status
ntpq -p

# Check synchronization
ntpstat
