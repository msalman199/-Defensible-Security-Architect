Task 1: Install and Configure Vulnerable SNMPv3
Step 1: Install SNMP Packages
# Update repositories and install SNMP tools
sudo apt update
sudo apt install -y snmpd snmp libsnmp-dev python3-pip

# Install Python SNMP library
pip3 install pysnmp
Step 2: Create Vulnerable SNMPv3 Configuration
# Backup original configuration
sudo cp /etc/snmp/snmpd.conf /etc/snmp/snmpd.conf.backup

# Create intentionally vulnerable configuration for testing
sudo tee /etc/snmp/snmpd.conf > /dev/null << 'EOF'
# Vulnerable SNMPv3 Configuration (Lab Testing Only)

agentAddress udp:161

# Weak authentication users
createUser weakuser MD5 "password123" DES "enckey123"
createUser testuser SHA "short" AES "weak"

# Overly permissive access
rouser weakuser
rwuser testuser

view all included .1 80

# Restart and enable service
sudo systemctl restart snmpd
sudo systemctl enable snmpd
Step 3: Verify SNMP Service
# Check service status
sudo systemctl status snmpd

# Test SNMP query
snmpget -v3 -u weakuser -l authPriv -a MD5 -A "password123" -x DES -X "enckey123" localhost 1.3.6.1.2.1.1.1.0
