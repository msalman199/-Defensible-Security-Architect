Task 1: Deploy Pi-hole DNS Sinkhole
Step 1.1: Prepare the Environment
# Update system and install dependencies
sudo apt update && sudo apt upgrade -y
sudo apt install -y curl wget git python3-pip docker.io docker-compose

# Configure Docker
sudo systemctl start docker
sudo systemctl enable docker
sudo usermod -aG docker $USER
newgrp docker

# Create project directory
mkdir -p ~/dns-sinkhole-lab && cd ~/dns-sinkhole-lab
Step 1.2: Deploy Pi-hole Container
Create a Docker Compose configuration:

# Create Pi-hole directories
mkdir -p pihole/{etc-pihole,etc-dnsmasq.d}

# Create docker-compose.yml
cat > docker-compose.yml << 'EOF'
version: '3.8'

services:
  pihole:
    container_name: pihole
    image: pihole/pihole:latest
    ports:
      - "53:53/tcp"
      - "53:53/udp"
      - "80:80/tcp"
    environment:
      TZ: 'America/New_York'
      WEBPASSWORD: 'SecurePassword123!'
      PIHOLE_DNS_: '8.8.8.8;8.8.4.4'
      DNSMASQ_LISTENING: 'all'
    volumes:
      - './pihole/etc-pihole:/etc/pihole'
      - './pihole/etc-dnsmasq.d:/etc/dnsmasq.d'
    cap_add:
      - NET_ADMIN
    restart: unless-stopped
EOF

# Deploy Pi-hole
docker-compose up -d

# Wait for initialization
sleep 30

# Verify deployment
docker-compose ps
MACHINE_IP=$(hostname -I | awk '{print $1}')
echo "Pi-hole Web Interface: http://$MACHINE_IP"
Step 1.3: Configure Threat Intelligence Feeds
# Add custom blocklists
docker exec pihole pihole -a -addlist https://raw.githubusercontent.com/StevenBlack/hosts/master/hosts
docker exec pihole pihole -a -addlist https://someonewhocares.org/hosts/zero/hosts

# Update gravity database
docker exec pihole pihole -g

# Verify blocklists
docker exec pihole pihole -q -adlist
Task 2: Deploy ELK Stack for Log Analysis
Step 2.1: Create ELK Stack Configuration
# Create ELK directories
mkdir -p elk-stack/{elasticsearch/data,logstash/{config,pipeline},kibana/config}
sudo chown -R 1000:1000 elk-stack/elasticsearch/data

# Create ELK docker-compose file
cat > elk-docker-compose.yml << 'EOF'
version: '3.8'

services:
  elasticsearch:
    image: docker.elastic.co/elasticsearch/elasticsearch:8.11.0
    container_name: elasticsearch
    environment:
      - discovery.type=single-node
      - xpack.security.enabled=false
      - "ES_JAVA_OPTS=-Xms512m -Xmx512m"
    ports:
      - "9200:9200"
    volumes:
      - ./elk-stack/elasticsearch/data:/usr/share/elasticsearch/data
    restart: unless-stopped

  logstash:
    image: docker.elastic.co/logstash/logstash:8.11.0
    container_name: logstash
    ports:
      - "5044:5044"
    volumes:
      - ./elk-stack/logstash/config:/usr/share/logstash/config
      - ./elk-stack/logstash/pipeline:/usr/share/logstash/pipeline
      - ./pihole/etc-pihole:/var/log/pihole:ro
    depends_on:
      - elasticsearch
    restart: unless-stopped

  kibana:
    image: docker.elastic.co/kibana/kibana:8.11.0
    container_name: kibana
    ports:
      - "5601:5601"
    environment:
      - ELASTICSEARCH_HOSTS=http://elasticsearch:9200
    depends_on:
      - elasticsearch
    restart: unless-stopped
EOF
Step 2.2: Configure Logstash Pipeline
# Create Logstash configuration
cat > elk-stack/logstash/config/logstash.yml << 'EOF'
http.host: "0.0.0.0"
xpack.monitoring.elasticsearch.hosts: [ "http://elasticsearch:9200" ]
path.config: /usr/share/logstash/pipeline
EOF

# Create pipeline configuration
cat > elk-stack/logstash/pipeline/pihole.conf << 'EOF'
input {
  file {
    path => "/var/log/pihole/pihole.log"
    start_position => "beginning"
    sincedb_path => "/dev/null"
  }
}

filter {
  grok {
    match => { 
      "message" => "%{SYSLOGTIMESTAMP:timestamp} %{WORD:hostname} %{WORD:process}: %{GREEDYDATA:query_info}" 
    }
  }
  
  if [query_info] =~ "query" {
    grok {
      match => { 
        "query_info" => "query\[%{WORD:query_type}\] %{HOSTNAME:domain} from %{IP:client_ip}" 
      }
    }
    mutate { add_field => { "action" => "query" } }
  }
  
  if [query_info] =~ "blocked" {
    grok {
      match => { 
        "query_info" => "blocked %{HOSTNAME:domain}" 
      }
    }
    mutate { add_field => { "action" => "blocked" } }
  }
  
  date {
    match => [ "timestamp", "MMM dd HH:mm:ss" ]
  }
}

output {
  elasticsearch {
    hosts => ["elasticsearch:9200"]
    index => "pihole-logs-%{+YYYY.MM.dd}"
  }
}
EOF

# Deploy ELK stack
docker-compose -f elk-docker-compose.yml up -d
sleep 60

# Verify services
curl -X GET "localhost:9200/_cluster/health?pretty"
