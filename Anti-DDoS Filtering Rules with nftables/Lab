Create SYN flood detection rule:

nano ~/sigma_rules/ddos/syn_flood.yml
title: TCP SYN Flood Detection
id: ddos-001-syn-flood
status: experimental
description: Detects TCP SYN flood attacks
author: Security Team
date: 2024/01/01
tags:
    - attack.impact
    - attack.t1499.004
logsource:
    category: network
    product: nftables
detection:
    selection:
        protocol: tcp
        flags: syn
        state: new
    condition: selection
    timeframe: 60s
    count: 100
falsepositives:
    - High-traffic applications
    - Load testing
level: high
