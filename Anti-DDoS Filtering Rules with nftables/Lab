Task 1: Configure nftables Anti-DDoS Rules
Step 1.1: Examine Current nftables Configuration
Check the current nftables setup:

# Check nftables service status
sudo systemctl status nftables

# View current ruleset
sudo nft list ruleset

# Check version
nft --version
Step 1.2: Create Basic Anti-DDoS Configuration
Create the main nftables configuration:

sudo nano /etc/nftables/anti-ddos.nft
Add this configuration:

#!/usr/sbin/nft -f

flush ruleset

define WAN_IF = "eth0"
define SSH_PORT = 22
define HTTP_PORT = 80
define HTTPS_PORT = 443

table inet filter {
    set ddos_protection {
        type ipv4_addr
        timeout 1h
        size 65536
        flags dynamic
    }
    
    set whitelist {
        type ipv4_addr
        elements = { 127.0.0.1, 10.0.0.0/8, 192.168.0.0/16 }
    }
    
    chain input {
        type filter hook input priority filter; policy drop;
        
        iif "lo" accept
        ct state established,related accept
        ip saddr @whitelist accept
        ct state invalid drop
        
        # ICMP flood protection
        icmp type echo-request limit rate 5/second burst 10 packets accept
        icmp type echo-request drop
        
        # SYN flood protection
        tcp flags & (fin|syn|rst|ack) == syn limit rate 25/second burst 50 packets accept
        tcp flags & (fin|syn|rst|ack) == syn add @ddos_protection { ip saddr timeout 1h } drop
        
        # Port scan protection
        tcp flags & (fin|syn|rst|psh|ack|urg) == fin|syn|rst|psh|ack|urg drop
        tcp flags & (fin|syn|rst|psh|ack|urg) == 0 drop
        
        # SSH rate limiting
        tcp dport $SSH_PORT ct state new limit rate 3/minute burst 3 packets accept
        
        # HTTP/HTTPS connection limiting
        tcp dport { $HTTP_PORT, $HTTPS_PORT } ct state new limit rate 100/second burst 200 packets accept
        
        limit rate 10/minute burst 5 packets log prefix "nftables-dropped: " level info
    }
    
    chain forward {
        type filter hook forward priority filter; policy drop;
    }
    
    chain output {
        type filter hook output priority filter; policy accept;
    }
}
Step 1.3: Apply and Verify Configuration
Load and verify the configuration:

# Load configuration
sudo nft -f /etc/nftables/anti-ddos.nft

# Verify loaded rules
sudo nft list ruleset

# Enable on boot
