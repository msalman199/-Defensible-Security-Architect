Task 2: Integrate ModSecurity WAF
Step 1: Install ModSecurity
# Install ModSecurity and dependencies
sudo apt install -y libmodsecurity3 libmodsecurity-dev nginx-module-modsecurity

# Create directories
sudo mkdir -p /etc/nginx/modsec
sudo mkdir -p /var/log/modsec
Step 2: Configure ModSecurity
sudo nano /etc/nginx/modsec/modsecurity.conf
# Enable ModSecurity
SecRuleEngine On

# Request body handling
SecRequestBodyAccess On
SecRequestBodyLimit 13107200
SecRequestBodyNoFilesLimit 131072

# Response body handling
SecResponseBodyAccess On
SecResponseBodyLimit 524288

# Temporary directories
SecTmpDir /tmp/
SecDataDir /tmp/

# Audit logging
SecAuditEngine RelevantOnly
SecAuditLogRelevantStatus "^(?:5|4(?!04))"
SecAuditLogType Serial
SecAuditLog /var/log/modsec/audit.log

# Include OWASP CRS
Include /etc/nginx/modsec/crs-setup.conf
Include /etc/nginx/modsec/rules/*.conf
Step 3: Install OWASP Core Rule Set
# Download OWASP CRS
cd /tmp
wget https://github.com/coreruleset/coreruleset/archive/refs/tags/v4.0.0.tar.gz
tar -xzf v4.0.0.tar.gz

# Copy to ModSecurity directory
sudo cp -r coreruleset-4.0.0/rules /etc/nginx/modsec/
sudo cp coreruleset-4.0.0/crs-setup.conf.example /etc/nginx/modsec/crs-setup.conf

# Set permissions
sudo chown -R www-data:www-data /etc/nginx/modsec
sudo chown -R www-data:www-data /var/log/modsec
Configure CRS settings:

sudo nano /etc/nginx/modsec/crs-setup.conf
# Set paranoia level (1-4)
SecAction \
  "id:900000,\
   phase:1,\
   nolog,\
   pass,\
   setvar:tx.paranoia_level=2"

# Anomaly scoring threshold
SecAction \
  "id:900110,\
   phase:1,\
   nolog,\
   pass,\
   setvar:tx.inbound_anomaly_score_threshold=5"
Step 4: Create Custom WAF Rules
sudo mkdir -p /etc/nginx/modsec/custom-rules
sudo nano /etc/nginx/modsec/custom-rules/custom.conf
# Block admin path access
SecRule REQUEST_URI "@beginsWith /admin" \
    "id:1001,\
     phase:1,\
     block,\
     msg:'Admin access blocked',\
     tag:'custom/admin-block'"

# Enhanced SQL injection detection
SecRule ARGS "@detectSQLi" \
    "id:1002,\
     phase:2,\
     block,\
     msg:'SQL Injection detected',\
     tag:'custom/sqli'"

# Rate limiting per IP
SecAction \
    "id:1004,\
     phase:1,\
     nolog,\
     pass,\
     initcol:ip=%{REMOTE_ADDR},\
     setvar:ip.requests=+1,\
     expirevar:ip.requests=60"

SecRule IP:REQUESTS "@gt 60" \
    "id:1005,\
     phase:1,\
     block,\
     msg:'Rate limit exceeded',\
     tag:'custom/rate-limit'"
# Include custom rules
echo "Include /etc/nginx/modsec/custom-rules/*.conf" | sudo tee -a /etc/nginx/modsec/modsecurity.conf
Step 5: Enable ModSecurity in Nginx
# Load ModSecurity module
sudo nano /etc/nginx/modules-enabled/50-mod-modsecurity.conf
load_module modules/ngx_http_modsecurity_module.so;
Update Nginx configuration:

sudo nano /etc/nginx/sites-available/waf-proxy
Add these lines inside the server block:

    # Enable ModSecurity
    modsecurity on;
    modsecurity_rules_file /etc/nginx/modsec/modsecurity.conf;
# Test and restart Nginx
sudo nginx -t
sudo systemctl restart nginx
