Task 1: Deploy Hybrid Network Environment
Step 1.1: Create Lab Directory and Vagrantfile
Create your working directory:

mkdir ~/lab4-network-visibility
cd ~/lab4-network-visibility
Create a Vagrantfile to define the network topology:

# -*- mode: ruby -*-
# vi: set ft=ruby :

Vagrant.configure("2") do |config|
  # Web Server - DMZ and Internal Network
  config.vm.define "webserver" do |web|
    web.vm.box = "ubuntu/jammy64"
    web.vm.hostname = "webserver"
    web.vm.network "private_network", ip: "192.168.10.10", virtualbox__intnet: "internal_net"
    web.vm.network "private_network", ip: "10.0.1.10", virtualbox__intnet: "dmz_net"
    web.vm.provider "virtualbox" do |vb|
      vb.memory = "512"
      vb.cpus = 1
    end
    web.vm.provision "shell", inline: <<-SHELL
      apt-get update -qq
      apt-get install -y apache2 tcpdump net-tools
      echo "<h1>WebServer - $(hostname -I)</h1>" > /var/www/html/index.html
    SHELL
  end

  # Database Server - Internal Network Only
  config.vm.define "database" do |db|
    db.vm.box = "ubuntu/jammy64"
    db.vm.hostname = "database"
    db.vm.network "private_network", ip: "192.168.10.20", virtualbox__intnet: "internal_net"
    db.vm.provider "virtualbox" do |vb|
      vb.memory = "512"
      vb.cpus = 1
    end
    db.vm.provision "shell", inline: <<-SHELL
      apt-get update -qq
      apt-get install -y mysql-server tcpdump net-tools
    SHELL
  end

  # Router - All Networks
  config.vm.define "router" do |rt|
    rt.vm.box = "ubuntu/jammy64"
    rt.vm.hostname = "router"
    rt.vm.network "private_network", ip: "192.168.10.1", virtualbox__intnet: "internal_net"
    rt.vm.network "private_network", ip: "10.0.1.1", virtualbox__intnet: "dmz_net"
    rt.vm.network "private_network", ip: "172.16.1.1", virtualbox__intnet: "external_net"
    rt.vm.provider "virtualbox" do |vb|
      vb.memory = "512"
      vb.cpus = 1
    end
    rt.vm.provision "shell", inline: <<-SHELL
      apt-get update -qq
      apt-get install -y tcpdump net-tools
      echo 'net.ipv4.ip_forward=1' >> /etc/sysctl.conf
      sysctl -p
    SHELL
  end
end
Step 1.2: Launch Virtual Machines
Start the environment:

vagrant up
