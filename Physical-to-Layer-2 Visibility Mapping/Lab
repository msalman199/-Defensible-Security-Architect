Troubleshooting Tips
Issue: Vagrant VMs fail to start

# Check VirtualBox kernel module
sudo modprobe vboxdrv
sudo systemctl restart vboxdrv

# Verify VirtualBox installation
VBoxManage --version
Issue: No packets captured

# Verify interface is correct
ip link show

# Run tshark with elevated privileges
sudo tshark -i any -c 10

# Check VirtualBox network settings
VBoxManage list hostonlyifs
Issue: Cannot SSH into VMs

# Check VM status
vagrant status

# Reload specific VM
vagrant reload webserver

# Check SSH configuration
vagrant ssh-config webserver
Issue: Python script errors

# Verify Python version
python3 --version

# Install missing dependencies
pip3 install --user scapy

# Check file permissions
chmod +x *.py
