Task 3: Automate Container Security Checks Using Python Scripts
Subtask 3.1: Create Security Validation Script
# Create Python security validation script
tee security_checker.py > /dev/null << 'EOF'
#!/usr/bin/env python3
import docker
import subprocess
import json
import sys
from datetime import datetime

class ContainerSecurityChecker:
    def __init__(self):
        self.client = docker.from_env()
        self.results = {
            'timestamp': datetime.now().isoformat(),
            'containers': [],
            'security_summary': {
                'total_containers': 0,
                'secure_containers': 0,
                'issues_found': 0
            }
        }
    
    def check_apparmor_profile(self, container):
        """Check if container has AppArmor profile applied"""
        try:
            security_opts = container.attrs.get('HostConfig', {}).get('SecurityOpt', [])
            for opt in security_opts:
                if 'apparmor' in opt:
                    return True, opt
            return False, "No AppArmor profile found"
        except Exception as e:
            return False, f"Error checking AppArmor: {str(e)}"
    
    def check_selinux_context(self, container):
        """Check if container has SELinux context applied"""
        try:
            security_opts = container.attrs.get('HostConfig', {}).get('SecurityOpt', [])
            for opt in security_opts:
                if 'label' in opt:
                    return True, opt
            return False, "No SELinux context found"
        except Exception as e:
            return False, f"Error checking SELinux: {str(e)}"
    
    def check_capabilities(self, container):
        """Check container capabilities"""
        try:
            host_config = container.attrs.get('HostConfig', {})
            cap_drop = host_config.get('CapDrop', [])
            cap_add = host_config.get('CapAdd', [])
            
            issues = []
            if 'ALL' not in cap_drop:
                issues.append("Not all capabilities dropped")
            
            dangerous_caps = ['SYS_ADMIN', 'SYS_MODULE', 'DAC_OVERRIDE']
            for cap in cap_add:
                if cap in dangerous_caps:
                    issues.append(f"Dangerous capability added: {cap}")
            
            return len(issues) == 0, issues
        except Exception as e:
            return False, [f"Error checking capabilities: {str(e)}"]
    
    def check_readonly_filesystem(self, container):
        """Check if container filesystem is read-only"""
        try:
            readonly = container.attrs.get('HostConfig', {}).get('ReadonlyRootfs', False)
            return readonly, "Read-only filesystem" if readonly else "Writable filesystem"
        except Exception as e:
            return False, f"Error checking filesystem: {str(e)}"
    
    def check_user_namespace(self, container):
        """Check if container runs as non-root user"""
        try:
            config = container.attrs.get('Config', {})
            user = config.get('User', '')
            
            if user and user != 'root' and user != '0':
                return True, f"Running as user: {user}"
            else:
                return False, "Running as root user"
        except Exception as e:
            return False, f"Error checking user: {str(e)}"
    
    def analyze_container(self, container):
        """Perform comprehensive security analysis of a container"""
        container_info = {
            'name': container.name,
            'id': container.id[:12],
            'image': container.image.tags[0] if container.image.tags else 'unknown',
            'status': container.status,
            'security_checks': {},
            'issues': [],
            'security_score': 0
        }
        
        # Perform security checks
        checks = [
            ('apparmor', self.check_apparmor_profile),
            ('selinux', self.check_selinux_context),
            ('capabilities', self.check_capabilities),
            ('readonly_fs', self.check_readonly_filesystem),
            ('user_namespace', self.check_user_namespace)
        ]
        
        passed_checks = 0
        for check_name, check_func in checks:
            try:
                passed, details = check_func(container)
                container_info['security_checks'][check_name] = {
                    'passed': passed,
                    'details': details
                }
                if passed:
                    passed_checks += 1
                else:
                    if isinstance(details, list):
                        container_info['issues'].extend(details)
                    else:
                        container_info['issues'].append(details)
            except Exception as e:
                container_info['issues'].append(f"Error in {check_name} check: {str(e)}")
        
        # Calculate security score
        container_info['security_score'] = (passed_checks / len(checks)) * 100
        
        return container_info
    
    def run_security_audit(self):
        """Run security audit on all running containers"""
        print("Starting Container Security Audit...")
        print("=" * 50)
        
        containers = self.client.containers.list()
        self.results['security_summary']['total_containers'] = len(containers)
        
        for container in containers:
            print(f"\nAnalyzing container: {container.name}")
            container_info = self.analyze_container(container)
            self.results['containers'].append(container_info)
            
            # Print summary for this container
            print(f"  Security Score: {container_info['security_score']:.1f}%")
            if container_info['issues']:
                print(f"  Issues Found: {len(container_info['issues'])}")
                for issue in container_info['issues']:
                    print(f"    - {issue}")
            else:
                print("  No security issues found!")
                self.results['security_summary']['secure_containers'] += 1
        
        # Calculate total issues
        total_issues = sum(len(c['issues']) for c in self.results['containers'])
        self.results['security_summary']['issues_found'] = total_issues
        
        return self.results
    
    def generate_report(self, output_file='security_report.json'):
        """Generate detailed security report"""
        with open(output_file, 'w') as f:
            json.dump(self.results, f, indent=2)
        
        print(f"\n" + "=" * 50)
        print("SECURITY AUDIT SUMMARY")
        print("=" * 50)
        print(f"Total Containers: {self.results['security_summary']['total_containers']}")
        print(f"Secure Containers: {self.results['security_summary']['secure_containers']}")
        print(f"Total Issues Found: {self.results['security_summary']['issues_found']}")
        print(f"Detailed report saved to: {output_file}")

def main():
    checker = ContainerSecurityChecker()
    try:
        checker.run_security_audit()
        checker.generate_report()
    except Exception as e:
        print(f"Error during security audit: {str(e)}")
        sys.exit(1)

if __name__ == "__main__":
    main()
EOF

