# Create script to fix common security issues
tee security_remediation.py > /dev/null << 'EOF'
#!/usr/bin/env python3
import docker
import json
import sys

class SecurityRemediator:
    def __init__(self):
        self.client = docker.from_env()
    
    def remediate_container(self, container_name, fixes):
        """Apply security fixes to a container"""
        try:
            container = self.client.containers.get(container_name)
            
            print(f"Remediating container: {container_name}")
            
            # Stop the container
            container.stop()
            
            # Get current configuration
            config = container.attrs
            image = config['Config']['Image']
            
            # Build new security options
            security_opts = []
            
            if 'apparmor' in fixes:
                security_opts.append('apparmor=docker-secure')
                print("  ✅ Added AppArmor profile")
            
            if 'selinux' in fixes:
                security_opts.append('label=type:container_t')
                print("  ✅ Added SELinux context")
            
            # Remove old container
            container.remove()
            
            # Create new secure container
            new_container = self.client.containers.run(
                image,
                name=f"{container_name}-secure",
                security_opt=security_opts,
                read_only=True,
                tmpfs={'/tmp': ''},
                cap_drop=['ALL'],
                cap_add=['NET_BIND_SERVICE'],
                detach=True,
                ports={'8080/tcp': None}  # Auto-assign port
            )
            
            print(f"  ✅ Created secure container: {new_container.name}")
            return True
            
        except Exception as e:
            print(f"  ❌ Error remediating {container_name}: {e}")
            return False
    
    def auto_remediate(self, report_file='security_report.json'):
        """Automatically remediate containers based on security report"""
        try:
            with open(report_file, 'r') as f:
                report = json.load(f)
            
            print("Starting automatic remediation...")
            print("=" * 40)
            
            for container_info in report['containers']:
                if container_info['security_score'] < 80:  # Remediate if score < 80%
                    fixes = []
                    
                    # Determine what fixes are needed
                    if not container_info['security_checks']['apparmor']['passed']:
                        fixes.append('apparmor')
                    
                    if not container_info['security_checks']['selinux']['passed']:
                        fixes.append('selinux')
                    
                    if fixes:
                        self.remediate_container(container_info['name'], fixes)
                    else:
                        print(f"No automatic fixes available for {container_info['name']}")
                else:
                    print(f"Container {container_info['name']} already secure (score: {container_info['security_score']:.1f}%)")
            
        except Exception as e:
            print(f"Error during auto-remediation: {e}")

def main():
    remediator = SecurityRemediator()
    
    if len(sys.argv) > 1:
        if sys.argv[1] == 'auto':
            remediator.auto_remediate()
        else:
            # Manual remediation
            container_name = sys.argv[1]
            fixes = sys.argv[2:] if len(sys.argv) > 2 else ['apparmor', 'selinux']
            remediator.remediate_container(container_name, fixes)
    else:
        print("Usage:")
        print("  python3 security_remediation.py auto")
        print("  python3 security_remediation.py <container_name> [apparmor] [selinux]")

if __name__ == "__main__":
    main()
EOF

