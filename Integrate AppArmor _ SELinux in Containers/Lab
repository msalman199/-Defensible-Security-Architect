#!/usr/bin/env python3
import docker
import time
import requests
import statistics

def test_container_performance(container_name, port):
    """Test container response time"""
    url = f"http://localhost:{port}/status"
    response_times = []
    
    print(f"Testing {container_name} performance...")
    
    for i in range(10):
        start_time = time.time()
        try:
            response = requests.get(url, timeout=5)
            end_time = time.time()
            if response.status_code == 200:
                response_times.append((end_time - start_time) * 1000)  # Convert to ms
        except Exception as e:
            print(f"Request failed: {e}")
    
    if response_times:
        avg_time = statistics.mean(response_times)
        print(f"  Average response time: {avg_time:.2f}ms")
        return avg_time
    else:
        print("  No successful responses")
        return None

def main():
    # Test different container configurations
    containers = [
        ('secure-app-apparmor', 8081),
        ('secure-app-selinux', 8082),
        ('secure-app-combined', 8083)
    ]
    
    results = {}
    for name, port in containers:
        results[name] = test_container_performance(name, port)
    
    print("\nPerformance Summary:")
    print("-" * 30)
    for name, time_ms in results.items():
        if time_ms:
            print(f"{name}: {time_ms:.2f}ms")

if __name__ == "__main__":
    main()
EOF

