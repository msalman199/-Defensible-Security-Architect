# Create continuous monitoring script
tee security_monitor.py > /dev/null << 'EOF'
#!/usr/bin/env python3
import docker
import time
import json
import subprocess
from datetime import datetime

class SecurityMonitor:
    def __init__(self, interval=60):
        self.client = docker.from_env()
        self.interval = interval
        self.alerts = []
    
    def check_apparmor_violations(self):
        """Check for AppArmor violations in system logs"""
        try:
            result = subprocess.run(
                ['sudo', 'dmesg', '|', 'grep', 'apparmor'],
                shell=True,
                capture_output=True,
                text=True
            )
            if result.returncode == 0 and result.stdout:
                violations = result.stdout.strip().split('\n')
                recent_violations = [v for v in violations if 'DENIED' in v]
                return recent_violations
        except Exception as e:
            print(f"Error checking AppArmor violations: {e}")
        return []
    
    def check_selinux_denials(self):
        """Check for SELinux denials"""
        try:
            result = subprocess.run(
                ['sudo', 'ausearch', '-m', 'avc', '-ts', 'recent'],
                capture_output=True,
                text=True
            )
            if result.returncode == 0 and result.stdout:
                return result.stdout.strip().split('\n')
        except Exception as e:
            print(f"Error checking SELinux denials: {e}")
        return []
    
    def monitor_containers(self):
        """Monitor container security status"""
        print(f"Starting security monitoring (interval: {self.interval}s)")
        print("Press Ctrl+C to stop monitoring")
        
        try:
            while True:
                timestamp = datetime.now().strftime("%Y-%m-%d %H:%M:%S")
                print(f"\n[{timestamp}] Security Check")
                print("-" * 40)
                
                # Check running containers
                containers = self.client.containers.list()
                print(f"Monitoring {len(containers)} containers")
                
                # Check for security violations
                apparmor_violations = self.check_apparmor_violations()
                selinux_denials = self.check_selinux_denials()
                
                if apparmor_violations:
                    print(f"⚠️  AppArmor violations detected: {len(apparmor_violations)}")
                    for violation in apparmor_violations[-3:]:  # Show last 3
                        print(f"   {violation}")
                
                if selinux_denials:
                    print(f"⚠️  SELinux denials detected: {len(selinux_denials)}")
                    for denial in selinux_denials[-3:]:  # Show last 3
                        print(f"   {denial}")
                
                if not apparmor_violations and not selinux_denials:
                    print("✅ No security violations detected")
                
                time.sleep(self.interval)
                
        except KeyboardInterrupt:
            print("\nMonitoring stopped by user")
        except Exception as e:
            print(f"Error during monitoring: {e}")

def main():
    monitor = SecurityMonitor(interval=30)  # Check every 30 seconds
    monitor.monitor_containers()

if __name__ == "__main__":
    main()
EOF

