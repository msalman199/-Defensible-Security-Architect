Subtask 1.2: Configure AppArmor for Docker
Create a custom AppArmor profile for Docker containers:

# Create AppArmor profile directory
sudo mkdir -p /etc/apparmor.d/containers

# Create custom Docker profile
sudo tee /etc/apparmor.d/containers/docker-secure > /dev/null << 'EOF'
#include <tunables/global>

profile docker-secure flags=(attach_disconnected,mediate_deleted) {
  #include <abstractions/base>
  
  # Allow basic system access
  /bin/** ix,
  /usr/bin/** ix,
  /lib/** mr,
  /usr/lib/** mr,
  
  # Allow container filesystem access
  /var/lib/docker/containers/** rw,
  /var/lib/docker/overlay2/** rw,
  
  # Deny sensitive system access
  deny /proc/sys/** w,
  deny /sys/** w,
  deny /etc/shadow r,
  deny /etc/passwd w,
  
  # Network access
  network inet tcp,
  network inet udp,
  
  # Capability restrictions
  capability setuid,
  capability setgid,
  capability net_bind_service,
  deny capability sys_admin,
  deny capability sys_module,
}
EOF

# Load the AppArmor profile
sudo apparmor_parser -r /etc/apparmor.d/containers/docker-secure

# Verify profile is loaded
sudo aa-status | grep docker-secure
Subtask 1.3: Configure SELinux for Containers
Enable and configure SELinux for container security:

# Enable SELinux (if not already enabled)
sudo selinux-activate

# Set SELinux to enforcing mode
sudo setenforce 1

# Create SELinux policy for containers
sudo tee /tmp/container_security.te > /dev/null << 'EOF'
module container_security 1.0;

require {
    type container_t;
    type docker_t;
    class process { transition };
    class file { read write execute };
}

# Allow container transitions
allow docker_t container_t:process transition;

# Restrict container file access
neverallow container_t { etc_t shadow_t }:file { read write };
EOF

# Compile and install SELinux policy
sudo checkmodule -M -m -o /tmp/container_security.mod /tmp/container_security.te
sudo semodule_package -o /tmp/container_security.pp -m /tmp/container_security.mod
sudo semodule -i /tmp/container_security.pp

# Verify policy installation
sudo semodule -l | grep container_security
