Task 1: Install and Configure Zeek
Step 1.1: Install Zeek
# Update system and install dependencies
sudo apt update && sudo apt upgrade -y
sudo apt install -y cmake make gcc g++ flex bison libpcap-dev libssl-dev python3-dev swig zlib1g-dev

# Download and install Zeek
cd /tmp
wget https://download.zeek.org/zeek-5.0.0.tar.gz
tar -xzf zeek-5.0.0.tar.gz
cd zeek-5.0.0

# Configure, compile, and install
./configure --prefix=/opt/zeek
make -j$(nproc)
sudo make install

# Add to PATH
echo 'export PATH=/opt/zeek/bin:$PATH' >> ~/.bashrc
source ~/.bashrc
Step 1.2: Configure Zeek
# Identify your network interface
ip addr show

# Configure Zeek node (replace eth0 with your interface)
sudo tee /opt/zeek/etc/node.cfg << 'EOF'
[zeek]
type=standalone
host=localhost
interface=eth0
EOF

# Define local networks
sudo tee /opt/zeek/etc/networks.cfg << 'EOF'
10.0.0.0/8          Private IP space
172.16.0.0/12       Private IP space
192.168.0.0/16      Private IP space
EOF
Step 1.3: Start Zeek and Verify
# Deploy Zeek
sudo /opt/zeek/bin/zeekctl deploy

# Check status
sudo /opt/zeek/bin/zeekctl status

# Generate test traffic
curl http://httpbin.org/get
curl http://httpbin.org/post -d "test=data"

# Wait and check logs
sleep 10
sudo ls -la /opt/zeek/logs/current/
sudo head -20 /opt/zeek/logs/current/conn.log
Task 2: Set Up NetFlow Collection
Step 2.1: Install NetFlow Tools
# Install softflowd and nfcapd
sudo apt install -y softflowd nfcapd nfdump

# Create NetFlow data directory
sudo mkdir -p /var/log/netflow
sudo chown $USER:$USER /var/log/netflow
Step 2.2: Start NetFlow Collection
# Start nfcapd collector
nfcapd -w -D -p 9995 -l /var/log/netflow &

# Start softflowd to generate NetFlow data (replace eth0 with your interface)
sudo softflowd -i eth0 -n 127.0.0.1:9995 -v 5 -t maxlife=60 &

# Verify processes are running
ps aux | grep -E 'nfcapd|softflowd'
Step 2.3: Generate Traffic and Collect Data
# Generate diverse network traffic
for i in {1..5}; do
    curl -s http://httpbin.org/get > /dev/null
    curl -s http://httpbin.org/json > /dev/null
    ping -c 3 8.8.8.8 > /dev/null 2>&1
    sleep 2
done

# Wait for data collection
sleep 30

# Verify NetFlow data
ls -la /var/log/netflow/
nfdump -R /var/log/netflow/ | head -20
Step 2.4: Analyze NetFlow Data
# View all flows
nfdump -R /var/log/netflow/

# Top talkers by bytes
nfdump -R /var/log/netflow/ -s srcip/bytes -n 10

# Top protocols
nfdump -R /var/log/netflow/ -s proto/bytes -n 10

# Top destination ports
nfdump -R /var/log/netflow/ -s dstport/flows -n 10
