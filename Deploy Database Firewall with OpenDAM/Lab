Task 1: Install and Configure Database Monitoring
Step 1.1: Prepare the Environment
Update system and install dependencies:

# Update packages
sudo apt update && sudo apt upgrade -y

# Install required packages
sudo apt install -y python3 python3-pip mysql-server mysql-client
sudo apt install -y iptables-persistent netfilter-persistent

# Start MySQL
sudo systemctl start mysql
sudo systemctl enable mysql
Step 1.2: Secure MySQL Installation
Run MySQL secure installation:

sudo mysql_secure_installation
Configuration settings:

Root password: SecurePass123!
Remove anonymous users: Y
Disallow root login remotely: Y
Remove test database: Y
Reload privileges: Y
Step 1.3: Create Sample Database
Connect to MySQL and create test database:

mysql -u root -p
Execute SQL commands:

CREATE DATABASE company_db;
USE company_db;

CREATE TABLE employees (
    id INT AUTO_INCREMENT PRIMARY KEY,
    name VARCHAR(100),
    email VARCHAR(100),
    department VARCHAR(50),
    salary DECIMAL(10,2),
    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP
);

CREATE TABLE access_logs (
    id INT AUTO_INCREMENT PRIMARY KEY,
    user_name VARCHAR(50),
    action VARCHAR(100),
    table_name VARCHAR(50),
    timestamp TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    ip_address VARCHAR(15)
);

INSERT INTO employees (name, email, department, salary) VALUES
('John Doe', 'john@company.com', 'IT', 75000.00),
('Jane Smith', 'jane@company.com', 'HR', 65000.00);

CREATE USER 'app_user'@'localhost' IDENTIFIED BY 'AppPass123!';
CREATE USER 'readonly_user'@'localhost' IDENTIFIED BY 'ReadPass123!';

GRANT SELECT, INSERT, UPDATE ON company_db.* TO 'app_user'@'localhost';
GRANT SELECT ON company_db.* TO 'readonly_user'@'localhost';

FLUSH PRIVILEGES;
EXIT;
Step 1.4: Setup OpenDAM Directory Structure
Create monitoring system directories:

sudo mkdir -p /opt/opendam/{bin,config,logs,scripts}
sudo chown -R $USER:$USER /opt/opendam

cat > /opt/opendam/config/opendam.conf << 'EOF'
[database]
host = localhost
port = 3306
database = company_db
monitor_user = root
monitor_password = SecurePass123!

[monitoring]
log_file = /opt/opendam/logs/activity.log
alert_threshold = 5
suspicious_patterns = DROP,DELETE,TRUNCATE,ALTER USER,GRANT ALL

[alerts]
syslog_enabled = true
alert_log = /opt/opendam/logs/alerts.log
EOF
Step 1.5: Install Python Dependencies
pip3 install mysql-connector-python configparser

cat > /opt/opendam/requirements.txt << 'EOF'
mysql-connector-python==8.0.33
configparser==5.3.0
pandas==1.5.3
EOF
