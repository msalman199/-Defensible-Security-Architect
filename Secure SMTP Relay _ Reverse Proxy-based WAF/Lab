Task 1: Configure Secure SMTP Relay
Step 1.1: Install Required Packages
# Update system and install packages
sudo apt update && sudo apt upgrade -y
sudo apt install postfix postfix-pcre sasl2-bin libsasl2-modules fail2ban ufw -y
Configuration Note: Select "Internet Site" during Postfix installation and enter your hostname.

Step 1.2: Configure Postfix Security Settings
Create the main configuration file:

# Backup original configuration
sudo cp /etc/postfix/main.cf /etc/postfix/main.cf.backup

# Edit main configuration
sudo nano /etc/postfix/main.cf
Add these essential security settings:

# Basic Configuration
myhostname = mail.example.com
mydomain = example.com
inet_interfaces = all
inet_protocols = ipv4

# Security Settings
smtpd_banner = $myhostname ESMTP
disable_vrfy_command = yes
smtpd_helo_required = yes

# SASL Authentication
smtpd_sasl_auth_enable = yes
smtpd_sasl_type = dovecot
smtpd_sasl_path = private/auth
smtpd_sasl_security_options = noanonymous

# TLS Configuration
smtpd_use_tls = yes
smtpd_tls_security_level = may
smtpd_tls_cert_file = /etc/ssl/certs/ssl-cert-snakeoil.pem
smtpd_tls_key_file = /etc/ssl/private/ssl-cert-snakeoil.key
smtpd_tls_protocols = !SSLv2, !SSLv3, !TLSv1, !TLSv1.1

# Access Control
smtpd_recipient_restrictions = 
    permit_mynetworks,
    permit_sasl_authenticated,
    reject_unauth_destination,
    permit

# Rate Limiting
smtpd_client_connection_rate_limit = 30
smtpd_error_sleep_time = 1s
smtpd_soft_error_limit = 10
smtpd_hard_error_limit = 20
Step 1.3: Configure SASL Authentication
# Create SASL configuration
sudo mkdir -p /etc/postfix/sasl
sudo nano /etc/postfix/sasl/smtpd.conf
Add SASL settings:

pwcheck_method: auxprop
auxprop_plugin: sasldb
mech_list: PLAIN LOGIN CRAM-MD5
Create test user:

# Create SASL user (enter password when prompted)
sudo saslpasswd2 -c -u example.com testuser

# Set permissions
sudo chown postfix:sasl /etc/sasldb2
sudo chmod 640 /etc/sasldb2
Step 1.4: Configure Firewall Protection
# Enable UFW and allow necessary ports
sudo ufw --force enable
sudo ufw allow 22/tcp
sudo ufw allow 25/tcp
sudo ufw allow 587/tcp

# Create iptables rate limiting rules
sudo iptables -A INPUT -p tcp --dport 25 -m conntrack --ctstate NEW -m recent --set --name smtp
sudo iptables -A INPUT -p tcp --dport 25 -m conntrack --ctstate NEW -m recent --update --seconds 60 --hitcount 10 --name smtp -j DROP

# Save iptables rules
sudo netfilter-persistent save
Step 1.5: Configure Fail2Ban
# Create Postfix jail configuration
sudo nano /etc/fail2ban/jail.d/postfix.conf
Add jail configuration:

[postfix-sasl]
enabled = true
port = smtp,465,submission
filter = postfix-sasl
logpath = /var/log/mail.log
maxretry = 3
bantime = 3600
findtime = 600
Restart services:

sudo systemctl restart fail2ban
sudo systemctl restart postfix
sudo systemctl enable postfix fail2ban
Task 2: Deploy Nginx Reverse Proxy WAF
Step 2.1: Install Nginx and Dependencies
# Install Nginx with modules
sudo apt install nginx nginx-extras libnginx-mod-http-headers-more-filter -y

# Create WAF directory structure
sudo mkdir -p /etc/nginx/waf /var/log/nginx/waf /var/www/testapp
Step 2.2: Create WAF Rule Sets
# Create main WAF rules
sudo nano /etc/nginx/waf/waf-rules.conf
Add detection rules:

# Rate Limiting Zones
limit_req_zone $binary_remote_addr zone=login:10m rate=5r/m;
limit_req_zone $binary_remote_addr zone=general:10m rate=100r/m;
limit_conn_zone $binary_remote_addr zone=conn_limit:10m;

# SQL Injection Detection
map $args $sql_injection {
    default 0;
    ~*union.*select 1;
    ~*select.*from 1;
    ~*insert.*into 1;
    ~*drop.*table 1;
}

# XSS Detection
map $args $xss_attack {
    default 0;
    ~*<script 1;
    ~*javascript: 1;
    ~*onerror= 1;
    ~*alert\( 1;
}

# Path Traversal Detection
map $request_uri $path_traversal {
    default 0;
    ~*\.\./\.\. 1;
    ~*etc/passwd 1;
}

# Malicious User Agents
map $http_user_agent $blocked_agent {
    default 0;
    ~*sqlmap 1;
    ~*nikto 1;
    ~*nmap 1;
}
Create blocking rules:

sudo nano /etc/nginx/waf/blocking-rules.conf
# Block SQL injection
if ($sql_injection) {
    return 403 "SQL injection detected";
}

# Block XSS attacks
if ($xss_attack) {
    return 403 "XSS attack detected";
}

# Block path traversal
if ($path_traversal) {
    return 403 "Path traversal detected";
}

# Block malicious agents
if ($blocked_agent) {
    return 403 "Blocked user agent";
}

# Security headers
add_header X-Frame-Options "SAMEORIGIN" always;
add_header X-Content-Type-Options "nosniff" always;
add_header X-XSS-Protection "1; mode=block" always;
server_tokens off;
Step 2.3: Configure Virtual Host with WAF
Create test application:

sudo nano /var/www/testapp/index.html
<!DOCTYPE html>
<html>
<head><title>WAF Protected App</title></head>
<body>
    <h1>Test Application</h1>
    <form method="post" action="/login">
        <input type="text" name="username" placeholder="Username">
        <input type="password" name="password" placeholder="Password">
        <input type="submit" value="Login">
    </form>
</body>
</html>
Create virtual host:

sudo nano /etc/nginx/sites-available/waf-protected-site
server {
    listen 80;
    server_name testapp.local;
    
    # Include WAF rules
    include /etc/nginx/waf/waf-rules.conf;
    include /etc/nginx/waf/blocking-rules.conf;
    
    # Rate limiting
    limit_req zone=general burst=50 nodelay;
    limit_conn conn_limit 10;
    
    # Logging
    access_log /var/log/nginx/waf/access.log combined;
    error_log /var/log/nginx/waf/error.log warn;
    
    root /var/www/testapp;
    index index.html;
    
    location / {
        try_files $uri $uri/ =404;
    }
    
    location /login {
        limit_req zone=login burst=3 nodelay;
        try_files $uri $uri/ =404;
    }
    
    # Block sensitive files
    location ~* \.(htaccess|ini|log|conf)$ {
        deny all;
    }
}
Enable site and restart:

sudo ln -s /etc/nginx/sites-available/waf-protected-site /etc/nginx/sites-enabled/
sudo rm -f /etc/nginx/sites-enabled/default
sudo nginx -t
sudo systemctl restart nginx
sudo systemctl enable nginx
