Task 1: Deploy OpenCanary Honeypot
Step 1: Install OpenCanary
# Update system and install dependencies
sudo apt update && sudo apt install python3-pip python3-venv libssl-dev -y

# Create virtual environment
python3 -m venv ~/opencanary-env
source ~/opencanary-env/bin/activate

# Install OpenCanary
pip install opencanary
Step 2: Configure OpenCanary
# Generate default configuration
opencanaryd --copyconfig

# Create working directory
mkdir -p ~/opencanary-config ~/opencanary-logs

# Copy configuration
cp ~/.opencanary.conf ~/opencanary-config/opencanary.conf
Edit the configuration file:

nano ~/opencanary-config/opencanary.conf
Key configuration settings to modify:

{
    "device.node_id": "darknet-monitor-01",
    "ftp.enabled": true,
    "ftp.port": 21,
    "http.enabled": true,
    "http.port": 80,
    "ssh.enabled": true,
    "ssh.port": 2222,
    "telnet.enabled": true,
    "telnet.port": 23,
    "mysql.enabled": true,
    "mysql.port": 3306,
    "logger": {
        "class": "PyLogger",
        "kwargs": {
            "handlers": {
                "file": {
                    "class": "logging.FileHandler",
                    "filename": "/home/ubuntu/opencanary-logs/opencanary.log"
                }
            }
        }
    }
}
Step 3: Start OpenCanary
# Start the honeypot
opencanaryd --start --config ~/opencanary-config/opencanary.conf

# Verify it's running
ps aux | grep opencanary

# Monitor logs
tail -f ~/opencanary-logs/opencanary.log
Step 4: Generate Test Traffic
Open a new terminal and generate sample alerts:

# Test SSH (use port 2222 as configured)
ssh admin@localhost -p 2222

# Test HTTP
curl http://localhost

# Test Telnet
telnet localhost 23

# Test FTP
ftp localhost
