#!/usr/bin/env python3
"""
Automated Firewall Rule Management Script
Lab 6: Configure Secure Routing on pfSense/firewalld
"""

import subprocess
import json
import logging
import schedule
import time
from datetime import datetime
import requests
import sys

# Configure logging
logging.basicConfig(
    level=logging.INFO,
    format='%(asctime)s - %(levelname)s - %(message)s',
    handlers=[
        logging.FileHandler('/var/log/firewall-automation.log'),
        logging.StreamHandler(sys.stdout)
    ]
)

class FirewallManager:
    def __init__(self):
        self.logger = logging.getLogger(__name__)
        self.blocked_ips = set()
        self.threat_feeds = [
            "https://raw.githubusercontent.com/firehol/blocklist-ipsets/master/firehol_level1.netset"
        ]
    
    def run_firewall_cmd(self, command):
        """Execute firewall-cmd commands safely"""
        try:
            result = subprocess.run(
                ['sudo', 'firewall-cmd'] + command.split(),
                capture_output=True,
                text=True,
                check=True
            )
            self.logger.info(f"Command executed: firewall-cmd {command}")
            return result.stdout.strip()
        except subprocess.CalledProcessError as e:
            self.logger.error(f"Command failed: {e}")
            return None
    
    def add_ip_to_blocklist(self, ip_address, zone='public'):
        """Add IP address to firewall blocklist"""
        if ip_address not in self.blocked_ips:
            command = f"--permanent --zone={zone} --add-rich-rule='rule family=\"ipv4\" source address=\"{ip_address}\" drop'"
            result = self.run_firewall_cmd(command)
            if result is not None:
                self.blocked_ips.add(ip_address)
                self.logger.info(f"Blocked IP: {ip_address}")
                return True
        return False
    
    def remove_ip_from_blocklist(self, ip_address, zone='public'):
        """Remove IP address from firewall blocklist"""
        if ip_address in self.blocked_ips:
            command = f"--permanent --zone={zone} --remove-rich-rule='rule family=\"ipv4\" source address=\"{ip_address}\" drop'"
            result = self.run_firewall_cmd(command)
            if result is not None:
                self.blocked_ips.discard(ip_address)
                self.logger.info(f"Unblocked IP: {ip_address}")
                return True
        return False
    
    def update_threat_intelligence(self):
        """Update firewall rules based on threat intelligence feeds"""
        self.logger.info("Updating threat intelligence feeds...")
        
        for feed_url in self.threat_feeds:
            try:
                response = requests.get(feed_url, timeout=30)
                if response.status_code == 200:
                    threat_ips = []
                    for line in response.text.split('\n'):
                        line = line.strip()
                        if line and not line.startswith('#'):
                            # Simple IP validation
                            if self.is_valid_ip(line):
                                threat_ips.append(line)
                    
                    # Add first 50 IPs to avoid overwhelming the firewall
                    for ip in threat_ips[:50]:
                        self.add_ip_to_blocklist(ip)
                    
                    self.logger.info(f"Added {len(threat_ips[:50])} threat IPs from {feed_url}")
                    
            except Exception as e:
                self.logger.error(f"Failed to update from {feed_url}: {e}")
        
        # Reload firewall rules
        self.run_firewall_cmd("--reload")
    
    def is_valid_ip(self, ip):
        """Basic IP address validation"""
        parts = ip.split('.')
        if len(parts) != 4:
            return False
        try:
            for part in parts:
                if not 0 <= int(part) <= 255:
                    return False
            return True
        except ValueError:
            return False
    
    def monitor_failed_logins(self):
        """Monitor system logs for failed login attempts"""
        try:
            result = subprocess.run(
                ['sudo', 'journalctl', '-u', 'ssh', '--since', '1 hour ago', '--grep', 'Failed password'],
                capture_output=True,
                text=True
            )
            
            failed_attempts = {}
            for line in result.stdout.split('\n'):
                if 'Failed password' in line:
                    # Extract IP address from log line
                    parts = line.split()
                    for i, part in enumerate(parts):
                        if part == 'from' and i + 1 < len(parts):
                            ip = parts[i + 1]
                            if self.is_valid_ip(ip):
                                failed_attempts[ip] = failed_attempts.get(ip, 0) + 1
            
            # Block IPs with more than 5 failed attempts
            for ip, count in failed_attempts.items():
                if count > 5:
                    self.add_ip_to_blocklist(ip)
                    self.logger.warning(f"Blocked IP {ip} after {count} failed login attempts")
        
        except Exception as e:
            self.logger.error(f"Error monitoring failed logins: {e}")
    
    def backup_firewall_config(self):
        """Create backup of current firewall configuration"""
        timestamp = datetime.now().strftime("%Y%m%d_%H%M%S")
        backup_file = f"/tmp/firewall_backup_{timestamp}.xml"
        
        try:
            # Export firewalld configuration
            result = subprocess.run(
                ['sudo', 'firewall-cmd', '--list-all-zones'],
                capture_output=True,
                text=True
            )
            
            with open(backup_file, 'w') as f:
                f.write(result.stdout)
            
            self.logger.info(f"Firewall configuration backed up to {backup_file}")
            
        except Exception as e:
            self.logger.error(f"Failed to backup firewall configuration: {e}")
    
    def generate_security_report(self):
        """Generate security report with current firewall status"""
        report = {
            'timestamp': datetime.now().isoformat(),
            'blocked_ips_count': len(self.blocked_ips),
            'active_zones': [],
            'services_allowed': {}
        }
        
        try:
            # Get active zones
            zones_result = self.run_firewall_cmd("--get-active-zones")
            if zones_result:
                report['active_zones'] = zones_result.split('\n')
            
            # Get services for each zone
            zones = self.run_firewall_cmd("--get-zones").split()
            for zone in zones:
                services = self.run_firewall_cmd(f"--zone={zone} --list-services")
                if services:
                    report['services_allowed'][zone] = services.split()
            
            # Save report
            report_file = f"/tmp/security_report_{datetime.now().strftime('%Y%m%d_%H%M%S')}.json"
            with open(report_file, 'w') as f:
                json.dump(report, f, indent=2)
            
            self.logger.info(f"Security report generated: {report_file}")
            
        except Exception as e:
            self.logger.error(f"Failed to generate security report: {e}")

def main():
    """Main function to run automated firewall management"""
    firewall_manager = FirewallManager()
    
    # Schedule automated tasks
    schedule.every(6).hours.do(firewall_manager.update_threat_intelligence)
    schedule.every(1).hours.do(firewall_manager.monitor_failed_logins)
    schedule.every(24).hours.do(firewall_manager.backup_firewall_config)
    schedule.every(12).hours.do(firewall_manager.generate_security_report)
    
    # Run initial setup
    firewall_manager.logger.info("Starting automated firewall management...")
    firewall_manager.update_threat_intelligence()
    firewall_manager.backup_firewall_config()
    
    # Keep the script running
    try:
        while True:
            schedule.run_pending()
            time.sleep(60)  # Check every minute
    except KeyboardInterrupt:
        firewall_manager.logger.info("Automated firewall management stopped by user")

if __name__ == "__main__":
    main()
