#!/usr/bin/env python3
"""
Network Monitoring and Alerting Script
Lab 6: Configure Secure Routing on pfSense/firewalld
"""

import psutil
import time
import smtplib
from email.mime.text import MIMEText
from email.mime.multipart import MIMEMultipart
import logging
import json
from datetime import datetime

class NetworkMonitor:
    def __init__(self):
        self.logger = logging.getLogger(__name__)
        self.baseline_connections = 0
        self.alert_threshold = 100  # connections
        self.bandwidth_threshold = 1000000  # bytes per second
        
    def get_network_stats(self):
        """Get current network statistics"""
        stats = {
            'connections': len(psutil.net_connections()),
            'bytes_sent': psutil.net_io_counters().bytes_sent,
            'bytes_recv': psutil.net_io_counters().bytes_recv,
            'packets_sent': psutil.net_io_counters().packets_sent,
            'packets_recv': psutil.net_io_counters().packets_recv,
            'timestamp': datetime.now().isoformat()
        }
        return stats
    
    def check_suspicious_activity(self):
        """Monitor for suspicious network activity"""
        current_stats = self.get_network_stats()
        
        # Check for unusual number of connections
        if current_stats['connections'] > self.alert_threshold:
            self.logger.warning(f"High connection count detected: {current_stats['connections']}")
            self.send_alert(f"High connection count: {current_stats['connections']}")
        
        # Monitor for port scanning attempts
        suspicious_ports = []
        connections = psutil.net_connections()
        
        for conn in connections:
            if conn.status == 'SYN_SENT' and conn.laddr.port > 1024:
                suspicious_ports.append(conn.laddr.port)
        
        if len(suspicious_ports) > 20:  # Many outbound connections
            self.logger.warning(f"Possible port scanning detected: {len(suspicious_ports)} connections")
            self.send_alert(f"Possible port scanning: {len(suspicious_ports)} outbound connections")
        
        return current_stats
    
    def send_alert(self, message):
        """Send alert notification (placeholder - configure with your email settings)"""
        self.logger.critical(f"ALERT: {message}")
        
        # In a real environment, configure SMTP settings
        alert_data = {
            'timestamp': datetime.now().isoformat(),
            'message': message,
            'severity': 'HIGH'
        }
        
        # Save alert to file
        with open('/tmp/security_alerts.json', 'a') as f:
            f.write(json.dumps(alert_data) + '\n')
    
    def monitor_continuously(self, interval=60):
        """Continuously monitor network activity"""
        self.logger.info("Starting continuous network monitoring...")
        
        while True:
            try:
                stats = self.check_suspicious_activity()
                self.logger.info(f"Network stats: {stats['connections']} connections")
                time.sleep(interval)
                
            except KeyboardInterrupt:
                self.logger.info("Monitoring stopped by user")
                break
            except Exception as e:
                self.logger.error(f"Monitoring error: {e}")
                time.sleep(interval)

def main():
    logging.basicConfig(level=logging.INFO)
    monitor = NetworkMonitor()
    monitor.monitor_continuously()

if __name__ == "__main__":
    main()
