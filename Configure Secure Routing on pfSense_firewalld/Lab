#!/usr/bin/env python3
"""
pfSense API Integration Script
Lab 6: Configure Secure Routing on pfSense/firewalld
"""

import requests
import json
import logging
from urllib3.exceptions import InsecureRequestWarning

# Disable SSL warnings for self-signed certificates
requests.urllib3.disable_warnings(InsecureRequestWarning)

class pfSenseAPI:
    def __init__(self, host, username, password):
        self.host = host
        self.username = username
        self.password = password
        self.session = requests.Session()
        self.session.verify = False
        self.logger = logging.getLogger(__name__)
        
    def login(self):
        """Authenticate with pfSense"""
        login_url = f"https://{self.host}/api/v1/access_token"
        
        try:
            response = self.session.post(
                login_url,
                json={
                    "client_id": self.username,
                    "client_token": self.password
                }
            )
            
            if response.status_code == 200:
                token_data = response.json()
                self.session.headers.update({
                    'Authorization': f'Bearer {token_data["data"]["token"]}'
                })
                self.logger.info("Successfully authenticated with pfSense")
                return True
            else:
                self.logger.error(f"Authentication failed: {response.status_code}")
                return False
                
        except Exception as e:
            self.logger.error(f"Login error: {e}")
            return False
    
    def get_firewall_rules(self):
        """Retrieve current firewall rules"""
        try:
            response = self.session.get(f"https://{self.host}/api/v1/firewall/rule")
            if response.status_code == 200:
                return response.json()
            else:
                self.logger.error(f"Failed to get rules: {response.status_code}")
                return None
        except Exception as e:
            self.logger.error(f"Error getting rules: {e}")
            return None
    
    def add_firewall_rule(self, rule_data):
        """Add new firewall rule"""
        try:
            response = self.session.post(
                f"https://{self.host}/api/v1/firewall/rule",
                json=rule_data
            )
            
            if response.status_code == 200:
                self.logger.info("Firewall rule added successfully")
                return response.json()
            else:
                self.logger.error(f"Failed to add rule: {response.status_code}")
                return None
                
        except Exception as e:
            self.logger.error(f"Error adding rule: {e}")
            return None

# Example usage
def main():
    # Configure for your pfSense instance
    pfsense = pfSenseAPI("192.168.100.1", "admin", "your_api_key")
    
    if pfsense.login():
