Step 1.3: Update Suricata Rules and Create Custom Rules
# Update default rules
sudo suricata-update

# Create custom rules directory
sudo mkdir -p /etc/suricata/rules/custom

# Create segmentation monitoring rules
sudo tee /etc/suricata/rules/custom/segmentation.rules > /dev/null << 'EOF'
# Network Segmentation Rules

# Alert on DMZ to Internal communication (should be blocked)
alert ip $DMZ_NET any -> $INTERNAL_NET any (msg:"DMZ to Internal communication attempt"; sid:1000001; rev:1;)

# Monitor cross-segment scanning
alert tcp any any -> any any (msg:"Port scan detected"; flags:S; threshold:type both, track by_src, count 20, seconds 60; sid:1000002; rev:1;)

# Database access monitoring
alert tcp any any -> any 3306 (msg:"MySQL access detected"; sid:1000003; rev:1;)
alert tcp any any -> any 5432 (msg:"PostgreSQL access detected"; sid:1000004; rev:1;)

# SSH access monitoring
alert tcp !$MGMT_NET any -> any 22 (msg:"SSH from non-management network"; sid:1000005; rev:1;)

# Large data transfers (potential exfiltration)
alert tcp $INTERNAL_NET any -> $EXTERNAL_NET any (msg:"Large outbound transfer"; dsize:>50000; threshold:type limit, track by_src, count 1, seconds 60; sid:1000006; rev:1;)
EOF

# Include custom rules
echo "include: /etc/suricata/rules/custom/segmentation.rules" | sudo tee -a /etc/suricata/suricata.yaml

# Test configuration
sudo suricata -T -c /etc/suricata/suricata.yaml

# Start Suricata
sudo systemctl enable suricata
sudo systemctl start suricata
sudo systemctl status suricata
Task 2: Configure nftables for Network Segmentation
Step 2.1: Install nftables
# Install nftables
sudo apt install -y nftables

# Enable nftables service
sudo systemctl enable nftables
Step 2.2: Create Segmentation Rules
# Create nftables configuration
sudo tee /etc/nftables.conf > /dev/null << 'EOF'
#!/usr/sbin/nft -f

flush ruleset

# Define network segments
define INTERNAL_NET = 192.168.1.0/24
define DMZ_NET = 192.168.100.0/24
define MGMT_NET = 192.168.200.0/24

# Define allowed services
define WEB_PORTS = { 80, 443 }
define SSH_PORT = 22
define DNS_PORT = 53

table inet filter {
    chain input {
        type filter hook input priority filter; policy drop;
        
        # Allow loopback and established connections
        iif lo accept
        ct state established,related accept
        
        # Allow ICMP
        ip protocol icmp accept
        
        # Allow SSH from management network only
        ip saddr $MGMT_NET tcp dport $SSH_PORT accept
        
        # Allow DNS
        tcp dport $DNS_PORT accept
        udp dport $DNS_PORT accept
        
        # Log and drop everything else
        log prefix "INPUT-DROP: " drop
    }
    
    chain forward {
        type filter hook forward priority filter; policy drop;
        
        # Allow established connections
        ct state established,related accept
        
        # Internal to DMZ: only web traffic
        ip saddr $INTERNAL_NET ip daddr $DMZ_NET tcp dport $WEB_PORTS accept
        
        # Internal to External: allow outbound
        ip saddr $INTERNAL_NET ip daddr != { $DMZ_NET, $MGMT_NET } accept
        
        # Management to all: allow management traffic
        ip saddr $MGMT_NET tcp dport { $SSH_PORT, 161, 443 } accept
        
        # DMZ to External: allow web traffic
        ip saddr $DMZ_NET ip daddr != { $INTERNAL_NET, $MGMT_NET } tcp dport $WEB_PORTS accept
        
        # Block DMZ to Internal (critical segmentation rule)
        ip saddr $DMZ_NET ip daddr $INTERNAL_NET log prefix "DMZ-TO-INTERNAL-BLOCK: " drop
        
        # Log all other drops
        log prefix "FORWARD-DROP: " drop
    }
    
    chain output {
        type filter hook output priority filter; policy accept;
    }
}

table inet nat {
    chain prerouting {
        type nat hook prerouting priority dstnat; policy accept;
    }
    
    chain postrouting {
        type nat hook postrouting priority srcnat; policy accept;
        
        # Masquerade outbound traffic
        ip saddr { $INTERNAL_NET, $DMZ_NET, $MGMT_NET } oif eth0 masquerade
    }
}
EOF

# Apply configuration
sudo nft -f /etc/nftables.conf

# Verify rules
sudo nft list ruleset
Step 2.3: Enable IP Forwarding
# Enable IP forwarding
echo "net.ipv4.ip_forward=1" | sudo tee -a /etc/sysctl.conf
sudo sysctl -p
