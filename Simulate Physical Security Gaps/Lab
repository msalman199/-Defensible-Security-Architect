Subtask 2.2: Generate Network Traffic
Create a script to generate various types of network traffic that simulates physical security breaches:
cat > generate_traffic.py << 'EOF'
#!/usr/bin/env python3
import subprocess
import time
import threading
import requests
from ftplib import FTP
import telnetlib

def http_traffic():
    """Generate HTTP traffic to simulate web browsing"""
    try:
        for i in range(10):
            response = requests.get('http://localhost:8080', timeout=5)
            print(f"HTTP request {i+1}: Status {response.status_code}")
            time.sleep(2)
    except Exception as e:
        print(f"HTTP traffic error: {e}")

def ftp_traffic():
    """Generate FTP traffic to simulate file transfers"""
    try:
        ftp = FTP()
        ftp.connect('localhost', 2121)
        ftp.login('anonymous', 'anonymous@example.com')
        ftp.retrlines('LIST')
        ftp.quit()
        print("FTP anonymous login successful - Security Gap Detected!")
    except Exception as e:
        print(f"FTP traffic error: {e}")

def ssh_traffic():
    """Generate SSH traffic"""
    try:
        for i in range(5):
            result = subprocess.run(['ssh', '-p', '2222', '-o', 'ConnectTimeout=5', 
                                   'vagrant@localhost', 'echo "SSH test"'], 
                                  capture_output=True, text=True, timeout=10)
            print(f"SSH attempt {i+1}")
            time.sleep(3)
    except Exception as e:
        print(f"SSH traffic error: {e}")

def main():
    print("Starting traffic generation to simulate physical security gaps...")
    
    # Create threads for different traffic types
    threads = [
        threading.Thread(target=http_traffic),
        threading.Thread(target=ftp_traffic),
        threading.Thread(target=ssh_traffic)
    ]
    
    # Start all threads
    for thread in threads:
        thread.start()
        time.sleep(1)
    
    # Wait for all threads to complete
    for thread in threads:
        thread.join()
    
    print("Traffic generation completed")

if __name__ == "__main__":
    main()
EOF
