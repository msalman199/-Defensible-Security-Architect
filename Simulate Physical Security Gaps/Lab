Task 3: Write Python Scripts to Log Traffic Data and Analyze Vulnerabilities
Subtask 3.1: Create Traffic Logging Script
Create a comprehensive traffic logging script:
cat > traffic_logger.py << 'EOF'
#!/usr/bin/env python3
import subprocess
import json
import time
import datetime
import os
from collections import defaultdict

class TrafficLogger:
    def __init__(self, interface="vboxnet0", log_file="traffic_log.json"):
        self.interface = interface
        self.log_file = log_file
        self.traffic_data = []
        
    def capture_traffic(self, duration=60):
        """Capture network traffic for specified duration"""
        print(f"Starting traffic capture on {self.interface} for {duration} seconds...")
        
        # Use tcpdump to capture traffic
        cmd = [
            'sudo', 'tcpdump', '-i', self.interface, '-n', '-c', '100',
            '-w', 'temp_capture.pcap'
        ]
        
        try:
            subprocess.run(cmd, timeout=duration, check=True)
            print("Traffic capture completed")
            return True
        except subprocess.TimeoutExpired:
            print("Capture timeout - analyzing collected data")
            return True
        except Exception as e:
            print(f"Capture error: {e}")
            return False
    
    def analyze_pcap(self, pcap_file="temp_capture.pcap"):
        """Analyze captured pcap file"""
        if not os.path.exists(pcap_file):
            print(f"PCAP file {pcap_file} not found")
            return
            
        # Use tcpdump to read and analyze the pcap file
        cmd = ['tcpdump', '-r', pcap_file, '-n', '-q']
        
        try:
            result = subprocess.run(cmd, capture_output=True, text=True, check=True)
            lines = result.stdout.strip().split('\n')
            
            for line in lines:
                if line.strip():
                    self.parse_traffic_line(line)
                    
        except Exception as e:
            print(f"Analysis error: {e}")
    
    def parse_traffic_line(self, line):
        """Parse individual traffic line and extract information"""
        timestamp = datetime.datetime.now().isoformat()
        
        traffic_entry = {
            'timestamp': timestamp,
            'raw_data': line,
            'protocol': 'unknown',
            'source': 'unknown',
            'destination': 'unknown',
            'security_risk': 'low'
        }
        
        # Basic protocol detection
        if 'FTP' in line.upper() or ':21 ' in line:
            traffic_entry['protocol'] = 'FTP'
            traffic_entry['security_risk'] = 'high'
            traffic_entry['vulnerability'] = 'Unencrypted file transfer protocol'
            
        elif 'HTTP' in line.upper() or ':80 ' in line:
            traffic_entry['protocol'] = 'HTTP'
            traffic_entry['security_risk'] = 'medium'
            traffic_entry['vulnerability'] = 'Unencrypted web traffic'
            
        elif ':22 ' in line:
            traffic_entry['protocol'] = 'SSH'
            traffic_entry['security_risk'] = 'low'
            traffic_entry['vulnerability'] = 'Encrypted but check for brute force'
            
        elif ':23 ' in line:
            traffic_entry['protocol'] = 'TELNET'
            traffic_entry['security_risk'] = 'critical'
            traffic_entry['vulnerability'] = 'Completely unencrypted remote access'
        
        self.traffic_data.append(traffic_entry)
    
    def save_log(self):
        """Save traffic data to JSON file"""
        with open(self.log_file, 'w') as f:
            json.dump(self.traffic_data, f, indent=2)
        print(f"Traffic log saved to {self.log_file}")
    
    def generate_report(self):
        """Generate security analysis report"""
        if not self.traffic_data:
            print("No traffic data to analyze")
            return
            
        protocol_count = defaultdict(int)
        risk_count = defaultdict(int)
        vulnerabilities = []
        
        for entry in self.traffic_data:
            protocol_count[entry['protocol']] += 1
            risk_count[entry['security_risk']] += 1
            
            if entry['security_risk'] in ['high', 'critical']:
                vulnerabilities.append(entry)
        
        report = {
            'analysis_timestamp': datetime.datetime.now().isoformat(),
            'total_packets': len(self.traffic_data),
            'protocol_distribution': dict(protocol_count),
            'risk_distribution': dict(risk_count),
            'high_risk_vulnerabilities': len(vulnerabilities),
            'recommendations': self.generate_recommendations(risk_count, protocol_count)
        }
        
        # Save report
        with open('security_report.json', 'w') as f:
            json.dump(report, f, indent=2)
            
        # Print summary
        print("\n" + "="*50)
        print("PHYSICAL SECURITY GAP ANALYSIS REPORT")
        print("="*50)
        print(f"Total packets analyzed: {report['total_packets']}")
        print(f"High-risk vulnerabilities found: {report['high_risk_vulnerabilities']}")
        print("\nProtocol Distribution:")
        for protocol, count in protocol_count.items():
            print(f"  {protocol}: {count}")
        print("\nRisk Level Distribution:")
        for risk, count in risk_count.items():
            print(f"  {risk.upper()}: {count}")
        print("\nRecommendations:")
        for rec in report['recommendations']:
            print(f"  - {rec}")
        print("="*50)
        
        return report
    
    def generate_recommendations(self, risk_count, protocol_count):
        """Generate security recommendations based on analysis"""
        recommendations = []
        
        if risk_count['critical'] > 0:
            recommendations.append("CRITICAL: Disable Telnet service immediately - use SSH instead")
            
        if risk_count['high'] > 0:
            recommendations.append("HIGH: Secure FTP services - consider SFTP or disable anonymous access")
            
        if protocol_count['HTTP'] > 0:
            recommendations.append("MEDIUM: Implement HTTPS for web services")
            
        if protocol_count['SSH'] > 10:
            recommendations.append("Monitor SSH connections for potential brute force attacks")
            
        recommendations.extend([
            "Implement network segmentation to limit physical access impact",
            "Deploy intrusion detection systems (IDS) on network segments",
            "Regular security audits of physical network access points",
            "Implement port security on network switches",
            "Use VLANs to isolate sensitive network segments"
        ])
        
        return recommendations

def main():
    logger = TrafficLogger()
    
    print("Physical Security Gap Traffic Logger")
    print("This tool simulates monitoring of network traffic from physical security breaches")
    
    # Capture traffic
    if logger.capture_traffic(30):  # Capture for 30 seconds
        # Analyze captured data
        logger.analyze_pcap()
        
        # Save log and generate report
        logger.save_log()
        report = logger.generate_report()
        
        print(f"\nAnalysis complete. Check {logger.log_file} and security_report.json for details.")
    else:
        print("Traffic capture failed")

if __name__ == "__main__":
    main()
EOF
