#!/usr/bin/env python3
import json
import subprocess
import socket
import threading
import time
from datetime import datetime

class VulnerabilityAnalyzer:
    def __init__(self):
        self.vulnerabilities = []
        self.target_ip = "localhost"
        self.common_ports = [21, 22, 23, 80, 443, 3389, 5900]
        
    def port_scan(self, host, port, timeout=3):
        """Scan a single port"""
        try:
            sock = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
            sock.settimeout(timeout)
            result = sock.connect_ex((host, port))
            sock.close()
            return result == 0
        except:
            return False
    
    def scan_common_ports(self):
        """Scan common ports for open services"""
        print("Scanning for open ports (simulating physical network access)...")
        open_ports = []
        
        for port in self.common_ports:
            if self.port_scan(self.target_ip, port):
                open_ports.append(port)
                print(f"Port {port} is OPEN")
                
                # Analyze specific vulnerabilities
                vuln = self.analyze_port_vulnerability(port)
                if vuln:
                    self.vulnerabilities.append(vuln)
            else:
                print(f"Port {port} is closed")
        
        return open_ports
    
    def analyze_port_vulnerability(self, port):
        """Analyze vulnerability for specific port"""
        vulnerabilities_db = {
            21: {
                'service': 'FTP',
                'risk_level': 'HIGH',
                'description': 'FTP service detected - potential for unencrypted data transfer',
                'impact': 'Data interception, credential theft',
                'mitigation': 'Use SFTP or FTPS, disable anonymous access'
            },
            22: {
                'service': 'SSH',
                'risk_level': 'MEDIUM',
                'description': 'SSH service detected - secure but monitor for brute force',
                'impact': 'Potential unauthorized access if weak credentials',
                'mitigation': 'Use key-based authentication, implement fail2ban'
            },
            23: {
                'service': 'Telnet',
                'risk_level': 'CRITICAL',
                'description': 'Telnet service detected - completely unencrypted',
                'impact': 'Complete credential and data exposure',
                'mitigation': 'Disable Telnet, use SSH instead'
            },
            80: {
                'service': 'HTTP',
                'risk_level': 'MEDIUM',
                'description': 'HTTP web service detected - unencrypted web traffic',
                'impact': 'Data interception, session hijacking',
                'mitigation': 'Implement HTTPS with valid certificates'
            },
            443: {
                'service': 'HTTPS',
                'risk_level': 'LOW',
                'description': 'HTTPS service detected - encrypted web traffic',
                'impact': 'Low risk if properly configured',
                'mitigation': 'Ensure strong SSL/TLS configuration'
            }
        }
        
        if port in vulnerabilities_db:
            vuln = vulnerabilities_db[port].copy()
            vuln['port'] = port
            vuln['timestamp'] = datetime.now().isoformat()
            vuln['detected_via'] = 'Physical network access simulation'
            return vuln
        
        return None
    
    def test_ftp_anonymous(self):
        """Test for anonymous FTP access"""
        try:
            from ftplib import FTP
            ftp = FTP()
            ftp.connect('localhost', 2121, timeout=5)
            ftp.login('anonymous', 'anonymous@test.com')
            
            # If we get here, anonymous access is enabled
            vuln = {
                'service': 'FTP Anonymous Access',
                'port': 21,
                'risk_level': 'CRITICAL',
                'description': 'Anonymous FTP access is enabled',
                'impact': 'Unauthorized file access and potential data exfiltration',
                'mitigation': 'Disable anonymous access, implement proper authentication',
                'timestamp': datetime.now().isoformat(),
                'test_result': 'VULNERABLE - Anonymous login successful'
            }
            
            ftp.quit()
            self.vulnerabilities.append(vuln)
            print("CRITICAL: Anonymous FTP access detected!")
            return True
            
        except Exception as e:
            print(f"FTP anonymous test: {e}")
            return False
    
    def test_weak_services(self):
        """Test for weak or insecure services"""
        print("\nTesting for weak service configurations...")
        
        # Test FTP anonymous access
        self.test_ftp_anonymous()
        
        # Add more service-specific tests here
        print("Weak service testing completed")
    
    def generate_vulnerability_report(self):
        """Generate comprehensive vulnerability report"""
        if not self.vulnerabilities:
            print("No vulnerabilities detected")
            return
        
        # Sort vulnerabilities by risk level
        risk_order = {'CRITICAL': 0, 'HIGH': 1, 'MEDIUM': 2, 'LOW': 3}
        sorted_vulns = sorted(self.vulnerabilities, 
                            key=lambda x: risk_order.get(x['risk_level'], 4))
        
        report = {
            'scan_timestamp': datetime.now().isoformat(),
            'total_vulnerabilities': len(self.vulnerabilities),
            'vulnerabilities': sorted_vulns,
            'risk_summary': self.calculate_risk_summary(),
            'physical_security_recommendations': self.get_physical_security_recommendations()
        }
        
        # Save detailed report
        with open('vulnerability_report.json', 'w') as f:
            json.dump(report, f, indent=2)
        
        # Print summary
        self.print_vulnerability_summary(report)
        
        return report
    
    def calculate_risk_summary(self):
        """Calculate risk level summary"""
        risk_counts = {'CRITICAL': 0, 'HIGH': 0, 'MEDIUM': 0, 'LOW': 0}
        
        for vuln in self.vulnerabilities:
            risk_level = vuln.get('risk_level', 'UNKNOWN')
            if risk_level in risk_counts:
                risk_counts[risk_level] += 1
        
        return risk_counts
    
    def get_physical_security_recommendations(self):
        """Get physical security specific recommendations"""
        return [
            "Implement network access control (NAC) to prevent unauthorized device connections",
            "Use port security on network switches to limit MAC addresses per port",
            "Deploy network segmentation to isolate critical systems",
            "Implement VLAN isolation for different security zones",
            "Install physical security cameras near network access points",
            "Use locked network cabinets and secure cable management",
            "Implement intrusion detection systems (IDS) on network segments",
            "Regular physical security audits of network infrastructure",
            "Employee training on social engineering and physical security threats",
            "Implement visitor access controls and escort policies"
        ]
    
    def print_vulnerability_summary(self, report):
        """Print formatted vulnerability summary"""
        print("\n" + "="*60)
        print("PHYSICAL SECURITY VULNERABILITY ASSESSMENT REPORT")
        print("="*60)
        print(f"Scan completed: {report['scan_timestamp']}")
        print(f"Total vulnerabilities found: {report['total_vulnerabilities']}")
        
        print("\nRisk Level Summary:")
        for risk, count in report['risk_summary'].items():
            if count > 0:
                print(f"  {risk}: {count}")
        
        print("\nDetailed Vulnerabilities:")
        for i, vuln in enumerate(report['vulnerabilities'], 1):
            print(f"\n{i}. {vuln['service']} (Port {vuln['port']})")
            print(f"   Risk Level: {vuln['risk_level']}")
            print(f"   Description: {vuln['description']}")
            print(f"   Impact: {vuln['impact']}")
            print(f"   Mitigation: {vuln['mitigation']}")
        
        print("\nPhysical Security Recommendations:")
        for i, rec in enumerate(report['physical_security_recommendations'][:5], 1):
            print(f"  {i}. {rec}")
        
        print("\n" + "="*60)
        print("Report saved to: vulnerability_report.json")
        print("="*60)

def main():
    analyzer = VulnerabilityAnalyzer()
    
    print("Physical Security Vulnerability Analyzer")
    print("Simulating security assessment from physical network access point")
    print("-" * 60)
    
    # Scan for open ports
    open_ports = analyzer.scan_common_ports()
    
    # Test for weak service configurations
    analyzer.test_weak_services()
    
    # Generate comprehensive report
    analyzer.generate_vulnerability_report()

if __name__ == "__main__":
    main()
EOF
