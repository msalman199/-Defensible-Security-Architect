Task 1: Install and Configure strongSwan
Step 1.1: Install strongSwan Components
Install strongSwan with necessary plugins for modern cryptography:

# Update package repositories
sudo apt update

# Install strongSwan with PKI tools and plugins
sudo apt install -y strongswan strongswan-pki libcharon-extra-plugins

# Verify installation
sudo ipsec version
Step 1.2: Create PKI Infrastructure
Generate a Certificate Authority and certificates for authentication:

# Create directory structure
sudo mkdir -p /etc/ipsec.d/{cacerts,certs,private}

# Generate CA private key (4096-bit RSA)
sudo ipsec pki --gen --type rsa --size 4096 --outform pem > /etc/ipsec.d/private/ca-key.pem

# Create self-signed CA certificate (10-year validity)
sudo ipsec pki --self --ca --lifetime 3650 --in /etc/ipsec.d/private/ca-key.pem \
    --type rsa --dn "CN=VPN CA, O=Security Lab, C=US" \
    --outform pem > /etc/ipsec.d/cacerts/ca-cert.pem

# Generate server private key
sudo ipsec pki --gen --type rsa --size 4096 --outform pem > /etc/ipsec.d/private/server-key.pem

# Create server certificate signed by CA
sudo ipsec pki --pub --in /etc/ipsec.d/private/server-key.pem --type rsa | \
    sudo ipsec pki --issue --lifetime 1825 --cacert /etc/ipsec.d/cacerts/ca-cert.pem \
    --cakey /etc/ipsec.d/private/ca-key.pem --dn "CN=vpn.lab.local, O=Security Lab, C=US" \
    --san vpn.lab.local --flag serverAuth --flag ikeIntermediate \
    --outform pem > /etc/ipsec.d/certs/server-cert.pem

# Set secure permissions
sudo chmod 600 /etc/ipsec.d/private/*
sudo chmod 644 /etc/ipsec.d/cacerts/*
sudo chmod 644 /etc/ipsec.d/certs/*
Step 1.3: Configure strongSwan with Hardened Settings
Create a secure IPSec configuration:

# Backup original configuration
sudo cp /etc/ipsec.conf /etc/ipsec.conf.backup

# Create hardened configuration
sudo tee /etc/ipsec.conf > /dev/null << 'EOF'
config setup
    charondebug="ike 1, knl 1, cfg 0"
    uniqueids=no

conn %default
    ikelifetime=60m
    keylife=20m
    rekeymargin=3m
    keyingtries=1
    keyexchange=ikev2
    authby=rsasig
    ike=aes256gcm16-sha384-modp4096,aes256-sha384-modp4096!
    esp=aes256gcm16-sha384-modp4096,aes256-sha384-modp4096!
    compress=no
    dpdaction=restart
    dpddelay=30s
    dpdtimeout=120s

conn site-to-site
    left=%defaultroute
    leftid="CN=vpn.lab.local, O=Security Lab, C=US"
    leftcert=server-cert.pem
    leftsubnet=192.168.10.0/24
    right=%any
    rightsubnet=192.168.20.0/24
    auto=add
EOF

# Configure secrets
sudo tee /etc/ipsec.secrets > /dev/null << 'EOF'
: RSA server-key.pem
EOF

sudo chmod 600 /etc/ipsec.secrets
Step 1.4: Enable IP Forwarding and Start Service
# Enable IP forwarding
echo 'net.ipv4.ip_forward = 1' | sudo tee -a /etc/sysctl.conf
echo 'net.ipv4.conf.all.accept_redirects = 0' | sudo tee -a /etc/sysctl.conf
echo 'net.ipv4.conf.all.send_redirects = 0' | sudo tee -a /etc/sysctl.conf
sudo sysctl -p

# Start strongSwan
sudo ipsec start

# Verify status
sudo ipsec status
Task 2: Implement Security Best Practices
Step 2.1: Configure Firewall Rules for VPN
Create iptables rules to secure VPN traffic:

# Create firewall script
sudo tee /usr/local/bin/vpn-firewall.sh > /dev/null << 'EOF'
#!/bin/bash

# Set default policies
iptables -P INPUT DROP
iptables -P FORWARD DROP
iptables -P OUTPUT ACCEPT

# Allow loopback and established connections
iptables -A INPUT -i lo -j ACCEPT
iptables -A INPUT -m state --state ESTABLISHED,RELATED -j ACCEPT

# Allow SSH
iptables -A INPUT -p tcp --dport 22 -j ACCEPT

# Allow IKE (UDP 500) and NAT-T (UDP 4500)
iptables -A INPUT -p udp --dport 500 -j ACCEPT
iptables -A INPUT -p udp --dport 4500 -j ACCEPT

# Allow ESP protocol
iptables -A INPUT -p esp -j ACCEPT

# Allow VPN subnet forwarding
iptables -A FORWARD -s 192.168.10.0/24 -d 192.168.20.0/24 -j ACCEPT
iptables -A FORWARD -s 192.168.20.0/24 -d 192.168.10.0/24 -j ACCEPT

# Enable NAT for VPN traffic
iptables -t nat -A POSTROUTING -s 192.168.10.0/24 -o eth0 -j MASQUERADE

echo "VPN firewall configured"
EOF

sudo chmod +x /usr/local/bin/vpn-firewall.sh
sudo /usr/local/bin/vpn-firewall.sh
Step 2.2: Disable Weak Cryptographic Algorithms
Configure strongSwan to reject weak algorithms:

# Create crypto policy configuration
sudo tee /etc/strongswan.d/charon/crypto-policy.conf > /dev/null << 'EOF'
charon {
    plugins {
        # Disable weak encryption
        des { load = no }
        
        # Disable weak hashing
        md5 { load = no }
        sha1 { load = no }
        
        # Ensure strong random generation
        random {
            strong_random = yes
        }
    }
}
EOF

# Restart strongSwan to apply changes
sudo ipsec restart
