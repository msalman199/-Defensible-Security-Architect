Step 5.2: Create Security Pipeline Script
Create ~/security_pipeline.sh:

#!/bin/bash

set -e

REPORT_DIR="$HOME/security-reports"
TIMESTAMP=$(date +"%Y%m%d_%H%M%S")
LOG_FILE="$REPORT_DIR/pipeline_${TIMESTAMP}.log"

mkdir -p "$REPORT_DIR"

echo "Starting Docker Security Pipeline" | tee -a "$LOG_FILE"

# Update Grype database
echo "Updating vulnerability database..." | tee -a "$LOG_FILE"
grype db update >> "$LOG_FILE" 2>&1

# Get Docker images
IMAGES=$(docker images --format "{{.Repository}}:{{.Tag}}" | grep -v "<none>")
IMAGE_COUNT=$(echo "$IMAGES" | wc -l)

echo "Found $IMAGE_COUNT images to scan" | tee -a "$LOG_FILE"

# Scan each image
CRITICAL_COUNT=0
HIGH_COUNT=0

while IFS= read -r image; do
    echo "Scanning $image..." | tee -a "$LOG_FILE"
    
    TEMP_FILE="/tmp/scan_$$.json"
    grype "$image" -o json > "$TEMP_FILE" 2>/dev/null || true
    
    CRITICAL=$(jq '[.matches[] | select(.vulnerability.severity == "Critical")] | length' "$TEMP_FILE" 2>/dev/null || echo 0)
    HIGH=$(jq '[.matches[] | select(.vulnerability.severity == "High")] | length' "$TEMP_FILE" 2>/dev/null || echo 0)
    
    CRITICAL_COUNT=$((CRITICAL_COUNT + CRITICAL))
    HIGH_COUNT=$((HIGH_COUNT + HIGH))
    
    echo "$image: Critical=$CRITICAL, High=$HIGH" | tee -a "$LOG_FILE"
    
    rm -f "$TEMP_FILE"
done <<< "$IMAGES"

# Run Docker Bench
if [ -f "$HOME/docker-bench-security/docker-bench-security.sh" ]; then
    echo "Running Docker Bench Security..." | tee -a "$LOG_FILE"
    sudo "$HOME/docker-bench-security/docker-bench-security.sh" -l "$REPORT_DIR/bench_${TIMESTAMP}.log" >> "$LOG_FILE" 2>&1
fi

# Generate summary
echo "========================================" | tee -a "$LOG_FILE"
echo "SECURITY PIPELINE SUMMARY" | tee -a "$LOG_FILE"
echo "Images Scanned: $IMAGE_COUNT" | tee -a "$LOG_FILE"
echo "Critical Vulnerabilities: $CRITICAL_COUNT" | tee -a "$LOG_FILE"
echo "High Vulnerabilities: $HIGH_COUNT" | tee -a "$LOG_FILE"
echo "========================================" | tee -a "$LOG_FILE"

# Exit with error if critical vulnerabilities found
if [ "$CRITICAL_COUNT" -gt 0 ]; then
    echo "ERROR: Critical vulnerabilities detected!" | tee -a "$LOG_FILE"
    exit 1
fi

echo "Security pipeline completed successfully" | tee -a "$LOG_FILE"
