Task 3: Configure Wazuh DLP Rules
Step 3.1: Create Custom DLP Rules
# Create custom DLP rules
sudo tee /var/ossec/etc/rules/dlp_rules.xml > /dev/null << 'EOF'
<group name="dlp,">
  
  <rule id="100001" level="0">
    <decoded_as>json</decoded_as>
    <field name="alert_type">\.+</field>
    <description>DLP Alert Base Rule</description>
  </rule>
  
  <rule id="100002" level="10">
    <if_sid>100001</if_sid>
    <field name="alert_type">NEW_SENSITIVE_FILE</field>
    <description>DLP: New sensitive file detected</description>
    <group>dlp,pci_dss_3.4,gdpr_IV_32.2,</group>
  </rule>
  
  <rule id="100003" level="8">
    <if_sid>100001</if_sid>
    <field name="alert_type">MODIFIED_SENSITIVE_FILE</field>
    <description>DLP: Sensitive file modified</description>
    <group>dlp,pci_dss_3.4,gdpr_IV_32.2,</group>
  </rule>
  
  <rule id="100004" level="12">
    <if_sid>100001</if_sid>
    <field name="details.match_type">exact</field>
    <description>DLP: Exact sensitive data match</description>
    <group>dlp,pci_dss_3.4,gdpr_IV_32.2,</group>
  </rule>
  
  <rule id="100005" level="11">
    <if_sid>100001</if_sid>
    <field name="details.patterns.ssn">\.+</field>
    <description>DLP: SSN detected</description>
    <group>dlp,pci_dss_3.4,gdpr_IV_32.2,</group>
  </rule>
  
  <rule id="100006" level="12">
    <if_sid>100001</if_sid>
    <field name="details.patterns.credit_card">\.+</field>
    <description>DLP: Credit card detected</description>
    <group>dlp,pci_dss_3.4,</group>
  </rule>
  
</group>
EOF

# Restart Wazuh manager
sudo systemctl restart wazuh-manager
